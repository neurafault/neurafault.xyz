---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('research', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---
<Base title="Neurafault" description="Independent AI Security Research Lab. Breaking AI before it breaks you.">
  {/* Hero */}
  <section class="min-h-[85vh] flex items-center">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-20 sm:py-32">
      <div data-animate class="flex items-center gap-3 mb-4">
        <span class="text-[var(--color-text-muted)] text-xs">$ whoami</span>
      </div>
      <h1 data-animate data-animate-delay="100" class="text-[clamp(2rem,6vw,3.5rem)] font-bold leading-[1.1] tracking-tight mb-4">
        Breaking AI before<br class="hidden sm:block"/> it breaks you.
      </h1>
      <p data-animate data-animate-delay="200" class="text-[var(--color-text-secondary)] max-w-md mb-8 text-sm">
        Independent AI Security Research Lab. Pentesting, vulnerability research, and offensive security across AI and traditional systems.
      </p>
      <div data-animate data-animate-delay="300" class="flex gap-3">
        <a href="/research/" class="px-4 py-2 rounded text-sm font-medium hover:opacity-90 transition-all hover:-translate-y-0.5" style="background:var(--color-accent);color:var(--color-bg)">research</a>
        <a href="/tools/" class="px-4 py-2 border border-[var(--color-border)] rounded text-sm text-[var(--color-text)] hover:border-[var(--color-text-muted)] transition-all hover:-translate-y-0.5">tools</a>
        <a href="https://docs.neurafault.xyz" target="_blank" rel="noopener" class="px-4 py-2 border border-[var(--color-border)] rounded text-sm text-[var(--color-text)] hover:border-[var(--color-text-muted)] transition-all hover:-translate-y-0.5">docs ↗</a>
      </div>
    </div>
  </section>

  {/* Focus areas */}
  <section class="max-w-3xl mx-auto px-4 sm:px-6 pb-16">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
      {[
        { t: 'Pentesting', d: 'Break AI & web systems.' },
        { t: 'Research', d: 'Document findings.' },
        { t: 'Tools', d: 'Open-source security tools.' },
      ].map((c, i) => (
        <div data-animate data-animate-delay={i * 80} class="p-4 bg-[var(--color-surface)] border border-[var(--color-border)] rounded hover:border-[var(--color-text-muted)] transition-all hover:-translate-y-0.5">
          <h3 class="font-semibold mb-1 text-[var(--color-accent)] text-sm">{c.t}</h3>
          <p class="text-xs text-[var(--color-text-secondary)]">{c.d}</p>
        </div>
      ))}
    </div>
  </section>

  {/* Targets */}
  <section class="max-w-3xl mx-auto px-4 sm:px-6 pb-16">
    <div data-animate class="border border-[var(--color-border)] rounded p-5 space-y-2 text-sm">
      <p class="text-[var(--color-text-muted)] text-xs mb-3">$ cat ./targets</p>
      <p><span class="text-[var(--color-accent)] mr-2">&gt;</span>Prompt injection & jailbreaks</p>
      <p><span class="text-[var(--color-accent)] mr-2">&gt;</span>OWASP LLM Top 10 vectors</p>
      <p><span class="text-[var(--color-accent)] mr-2">&gt;</span>Agent & tool-use exploitation</p>
      <p><span class="text-[var(--color-accent)] mr-2">&gt;</span>Web app & API pentesting</p>
      <p><span class="text-[var(--color-accent)] mr-2">&gt;</span>Adversarial ML & data extraction</p>
    </div>
  </section>

  {/* Latest research */}
  <section class="max-w-3xl mx-auto px-4 sm:px-6 pb-20">
    <div class="flex items-baseline justify-between mb-5">
      <h2 data-animate class="text-lg font-semibold tracking-tight">Latest Research</h2>
      <a data-animate href="/research/" class="text-xs text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">all →</a>
    </div>
    {posts.length === 0 ? (
      <div data-animate class="border border-[var(--color-border)] rounded p-5 text-center">
        <p class="text-[var(--color-text-muted)] text-sm">No research published yet.</p>
        <p class="text-xs text-[var(--color-text-muted)] mt-2">First writeup coming soon. Subscribe via <a href="/index.xml" class="text-[var(--color-accent)]">RSS</a>.</p>
      </div>
    ) : (
      <div class="space-y-1">
        {posts.map((post, i) => (
          <a data-animate data-animate-delay={i * 60} href={`/research/${post.id}/`}
             class="flex items-baseline gap-4 py-3 border-b border-[var(--color-border)] last:border-b-0 hover:text-[var(--color-link)] transition-colors group">
            <time class="text-xs text-[var(--color-text-muted)] shrink-0">
              {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
            </time>
            <span class="text-sm group-hover:underline underline-offset-2">{post.data.title}</span>
            {post.data.severity && (
              <span class:list={[
                "ml-auto text-xs px-1.5 py-0.5 rounded",
                post.data.severity === 'critical' && "text-[#ff3333] border border-[#ff3333]/30",
                post.data.severity === 'high' && "text-[#ff8833] border border-[#ff8833]/30",
                post.data.severity === 'medium' && "text-[#ffcc00] border border-[#ffcc00]/30",
                post.data.severity === 'low' && "text-[var(--color-accent)] border border-[var(--color-accent)]/30",
                post.data.severity === 'info' && "text-[var(--color-text-muted)] border border-[var(--color-border)]",
              ]}>{post.data.severity}</span>
            )}
          </a>
        ))}
      </div>
    )}
  </section>
</Base>
