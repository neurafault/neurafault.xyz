---
import Base from '../layouts/Base.astro';
import ParticleNetwork from '../components/ParticleNetwork.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('research', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---
<Base title="Neurafault" description="AI Security Research by @hyrahmo. Vulnerability research, pentesting, and offensive security tools.">
  {/* Hero with particle network */}
  <section class="relative min-h-[85vh] flex items-center overflow-hidden">
    <ParticleNetwork />
    <div class="relative z-10 max-w-3xl mx-auto px-4 sm:px-6 py-20 sm:py-32">
      <p data-animate class="text-[var(--color-accent)] text-sm font-medium mb-4 tracking-wide">Independent Security Research</p>
      <h1 data-animate data-animate-delay="80" class="text-[clamp(2.25rem,7vw,4rem)] font-bold leading-[1.05] tracking-tight mb-6">
        Breaking AI<br/>before it breaks you.
      </h1>
      <p data-animate data-animate-delay="160" class="text-[var(--color-text-secondary)] max-w-lg mb-10 text-[15px] leading-relaxed">
        I research vulnerabilities in AI systems — LLMs, agents, multimodal models.
        Pentesting, adversarial ML, and open-source security tools.
      </p>
      <div data-animate data-animate-delay="240" class="flex flex-wrap gap-3">
        <a href="/research/" class="px-5 py-2.5 rounded-lg text-sm font-medium transition-all hover:shadow-[0_0_20px_rgba(74,222,128,0.15)]" style="background:var(--color-accent);color:var(--color-bg)">Read Research</a>
        <a href="/about/" class="px-5 py-2.5 border border-[var(--color-border)] rounded-lg text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-text)] hover:border-[var(--color-text-muted)] transition-all">About Me</a>
      </div>
    </div>
    {/* Bottom gradient fade */}
    <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[var(--color-bg)] to-transparent"></div>
  </section>

  {/* Focus areas */}
  <section class="max-w-3xl mx-auto px-4 sm:px-6 pb-20">
    <h2 data-animate class="text-xs font-semibold text-[var(--color-text-muted)] uppercase tracking-widest mb-8">What I research</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {[
        { t: 'LLM Vulnerabilities', d: 'Prompt injection, jailbreaks, output manipulation, and data extraction from large language models.' },
        { t: 'Agent Exploitation', d: 'Breaking tool-use chains, MCP servers, and autonomous AI agents.' },
        { t: 'Adversarial ML', d: 'Adversarial attacks on models — evasion, poisoning, model theft.' },
        { t: 'Web & API Security', d: 'Traditional pentesting — OWASP Top 10, API abuse, auth bypass.' },
      ].map((c, i) => (
        <div data-animate data-animate-delay={i * 60} class="group p-5 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] hover:border-[var(--color-accent-dim)]/30 transition-all duration-300">
          <h3 class="font-semibold text-sm mb-2 text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors">{c.t}</h3>
          <p class="text-xs text-[var(--color-text-secondary)] leading-relaxed">{c.d}</p>
        </div>
      ))}
    </div>
  </section>

  {/* Latest research */}
  <section class="max-w-3xl mx-auto px-4 sm:px-6 pb-24">
    <div class="flex items-baseline justify-between mb-8">
      <h2 data-animate class="text-xs font-semibold text-[var(--color-text-muted)] uppercase tracking-widest">Latest Research</h2>
      <a data-animate href="/research/" class="text-xs text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">View all →</a>
    </div>
    {posts.length === 0 ? (
      <div data-animate class="rounded-lg border border-[var(--color-border)] p-8 text-center">
        <p class="text-[var(--color-text-secondary)] text-sm mb-2">First research post coming soon.</p>
        <p class="text-xs text-[var(--color-text-muted)]">Subscribe via <a href="/index.xml" class="text-[var(--color-accent)] hover:underline">RSS</a> to get notified.</p>
      </div>
    ) : (
      <div class="space-y-0">
        {posts.map((post, i) => (
          <a data-animate data-animate-delay={i * 50} href={`/research/${post.id}/`}
             class="flex items-baseline gap-4 py-4 border-b border-[var(--color-border)] last:border-b-0 hover:text-[var(--color-accent)] transition-colors group">
            <time class="text-xs text-[var(--color-text-muted)] shrink-0 tabular-nums">
              {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
            </time>
            <span class="text-sm group-hover:underline underline-offset-4">{post.data.title}</span>
            {post.data.severity && (
              <span class:list={[
                "ml-auto text-xs px-2 py-0.5 rounded-full shrink-0",
                post.data.severity === 'critical' && "text-[#ff3333] bg-[#ff3333]/10",
                post.data.severity === 'high' && "text-[#ff8833] bg-[#ff8833]/10",
                post.data.severity === 'medium' && "text-[#ffcc00] bg-[#ffcc00]/10",
                post.data.severity === 'low' && "text-[var(--color-accent)] bg-[var(--color-accent)]/10",
                post.data.severity === 'info' && "text-[var(--color-text-muted)] bg-[var(--color-surface)]",
              ]}>{post.data.severity}</span>
            )}
          </a>
        ))}
      </div>
    )}
  </section>
</Base>
