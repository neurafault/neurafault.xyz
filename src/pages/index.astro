---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('research', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---
<Base title="Neurafault" description="Independent AI Security Research Lab. Breaking AI before it breaks you.">
  {/* Hero */}
  <section class="min-h-[80vh] flex items-center">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-20 sm:py-32">
      <h1 data-animate class="text-[clamp(2rem,6vw,3.5rem)] font-bold leading-[1.1] tracking-tight mb-6">
        AI Security<br class="hidden sm:block"/> Research Lab
      </h1>
      <p data-animate data-animate-delay="100" class="text-[var(--color-text-secondary)] max-w-lg mb-8 text-sm leading-relaxed">
        We find vulnerabilities in AI systems — LLMs, agents, multimodal models — before attackers do.
        Pentesting, research, and open-source security tools.
      </p>
      <div data-animate data-animate-delay="200" class="flex gap-3">
        <a href="/research/" class="px-4 py-2 rounded text-sm font-medium hover:opacity-90 transition-all" style="background:var(--color-accent);color:var(--color-bg)">Research</a>
        <a href="/tools/" class="px-4 py-2 border border-[var(--color-border)] rounded text-sm text-[var(--color-text)] hover:border-[var(--color-text-muted)] transition-colors">Tools</a>
        <a href="https://docs.neurafault.xyz" target="_blank" rel="noopener" class="px-4 py-2 border border-[var(--color-border)] rounded text-sm text-[var(--color-text)] hover:border-[var(--color-text-muted)] transition-colors">Docs ↗</a>
      </div>
    </div>
  </section>

  {/* What we do */}
  <section class="max-w-3xl mx-auto px-4 sm:px-6 pb-16">
    <h2 data-animate class="text-sm font-semibold text-[var(--color-text-muted)] uppercase tracking-wider mb-6">What we do</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      {[
        { t: 'Pentesting', d: 'Security testing of AI-powered applications, APIs, and web systems.' },
        { t: 'Research', d: 'Vulnerability research, CVE analysis, and adversarial ML studies.' },
        { t: 'Tools', d: 'Open-source tools for AI security testing and red teaming.' },
      ].map((c, i) => (
        <div data-animate data-animate-delay={i * 80} class="p-4 bg-[var(--color-surface)] border border-[var(--color-border)] rounded">
          <h3 class="font-semibold mb-2 text-sm">{c.t}</h3>
          <p class="text-xs text-[var(--color-text-secondary)] leading-relaxed">{c.d}</p>
        </div>
      ))}
    </div>
  </section>

  {/* Focus areas */}
  <section class="max-w-3xl mx-auto px-4 sm:px-6 pb-16">
    <h2 data-animate class="text-sm font-semibold text-[var(--color-text-muted)] uppercase tracking-wider mb-6">Focus areas</h2>
    <div data-animate data-animate-delay="80" class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-2 text-sm">
      {[
        'Prompt injection & jailbreaks',
        'OWASP LLM Top 10 vectors',
        'Agent & tool-use exploitation',
        'Web app & API pentesting',
        'Adversarial ML & data extraction',
        'AI red teaming',
      ].map(item => (
        <p class="py-2 border-b border-[var(--color-border)] text-[var(--color-text-secondary)]">{item}</p>
      ))}
    </div>
  </section>

  {/* Latest research */}
  <section class="max-w-3xl mx-auto px-4 sm:px-6 pb-20">
    <div class="flex items-baseline justify-between mb-6">
      <h2 data-animate class="text-sm font-semibold text-[var(--color-text-muted)] uppercase tracking-wider">Latest research</h2>
      <a data-animate href="/research/" class="text-xs text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">View all →</a>
    </div>
    {posts.length === 0 ? (
      <div data-animate class="border border-[var(--color-border)] rounded p-6 text-center">
        <p class="text-[var(--color-text-muted)] text-sm">No research published yet.</p>
        <p class="text-xs text-[var(--color-text-muted)] mt-2">Subscribe via <a href="/index.xml" class="text-[var(--color-accent)]">RSS</a> to get notified.</p>
      </div>
    ) : (
      <div class="space-y-1">
        {posts.map((post, i) => (
          <a data-animate data-animate-delay={i * 60} href={`/research/${post.id}/`}
             class="flex items-baseline gap-4 py-3 border-b border-[var(--color-border)] last:border-b-0 hover:text-[var(--color-link)] transition-colors group">
            <time class="text-xs text-[var(--color-text-muted)] shrink-0">
              {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
            </time>
            <span class="text-sm group-hover:underline underline-offset-2">{post.data.title}</span>
            {post.data.severity && (
              <span class:list={[
                "ml-auto text-xs px-1.5 py-0.5 rounded",
                post.data.severity === 'critical' && "text-[#ff3333] border border-[#ff3333]/30",
                post.data.severity === 'high' && "text-[#ff8833] border border-[#ff8833]/30",
                post.data.severity === 'medium' && "text-[#ffcc00] border border-[#ffcc00]/30",
                post.data.severity === 'low' && "text-[var(--color-accent)] border border-[var(--color-accent)]/30",
                post.data.severity === 'info' && "text-[var(--color-text-muted)] border border-[var(--color-border)]",
              ]}>{post.data.severity}</span>
            )}
          </a>
        ))}
      </div>
    )}
  </section>
</Base>
