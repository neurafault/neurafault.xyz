---
import Base from '../layouts/Base.astro';
import ParticleNetwork from '../components/ParticleNetwork.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('research', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---
<Base title="Neurafault" description="AI Security Research by @hyrahmo. Vulnerability research, pentesting, and offensive security tools.">
  {/* ─── Hero ─── */}
  <section class="relative min-h-[90vh] flex items-center overflow-hidden">
    <ParticleNetwork />
    <div class="relative z-10 max-w-4xl mx-auto px-6 sm:px-8 py-24 sm:py-36">
      <div data-animate class="inline-block px-3 py-1 rounded-full border border-[var(--color-border)] text-[11px] text-[var(--color-text-muted)] mb-8 backdrop-blur-sm">
        Independent Security Research
      </div>
      <h1 data-animate data-animate-delay="80" class="text-[clamp(2.5rem,8vw,5rem)] font-bold leading-[1.0] tracking-[-0.03em] mb-8">
        <span class="gradient-text">Breaking AI</span><br/>
        <span class="text-[var(--color-text)]">before it breaks you.</span>
      </h1>
      <p data-animate data-animate-delay="160" class="text-[var(--color-text-secondary)] max-w-xl mb-12 text-[15px] leading-[1.8]">
        I research vulnerabilities in AI systems — LLMs, agents, multimodal models.
        Pentesting, adversarial ML, and open-source security tools.
      </p>
      <div data-animate data-animate-delay="240" class="flex flex-wrap gap-4">
        <a href="/research/" class="btn-primary">Read Research <span class="opacity-50">→</span></a>
        <a href="/about/" class="btn-ghost">About</a>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-40 bg-gradient-to-t from-[var(--color-bg)] to-transparent"></div>
  </section>

  {/* ─── What I research ─── */}
  <section class="max-w-4xl mx-auto px-6 sm:px-8 pb-24">
    <div class="flex items-center gap-4 mb-10">
      <h2 data-animate class="section-label">What I research</h2>
      <div data-animate class="flex-1 h-px bg-[var(--color-border)]"></div>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      {[
        { icon: '01', t: 'LLM Vulnerabilities', d: 'Prompt injection, jailbreaks, output manipulation, and data extraction from large language models.' },
        { icon: '02', t: 'Agent Exploitation', d: 'Breaking tool-use chains, MCP servers, and autonomous AI agents before they reach production.' },
        { icon: '03', t: 'Adversarial ML', d: 'Evasion attacks, training data poisoning, model theft, and adversarial robustness testing.' },
        { icon: '04', t: 'Web & API Security', d: 'OWASP Top 10, API abuse, auth bypass, SSRF — traditional pentesting across modern stacks.' },
      ].map((c, i) => (
        <div data-animate data-animate-delay={i * 70} class="glow-card p-6 group">
          <span class="text-xs text-[var(--color-accent)] opacity-40 font-mono">{c.icon}</span>
          <h3 class="font-semibold text-sm mt-3 mb-3 text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors duration-300">{c.t}</h3>
          <p class="text-[13px] text-[var(--color-text-secondary)] leading-[1.7]">{c.d}</p>
        </div>
      ))}
    </div>
  </section>

  {/* ─── Latest Research ─── */}
  <section class="max-w-4xl mx-auto px-6 sm:px-8 pb-32">
    <div class="flex items-center gap-4 mb-10">
      <h2 data-animate class="section-label">Latest Research</h2>
      <div data-animate class="flex-1 h-px bg-[var(--color-border)]"></div>
      <a data-animate href="/research/" class="section-label hover:text-[var(--color-accent)] transition-colors">View all →</a>
    </div>
    {posts.length === 0 ? (
      <div data-animate class="glow-card p-10 text-center">
        <p class="text-[var(--color-text-secondary)] text-sm mb-3">First research post coming soon.</p>
        <p class="text-xs text-[var(--color-text-muted)]">Subscribe via <a href="/index.xml" class="text-[var(--color-accent)] hover:underline">RSS</a> to get notified.</p>
      </div>
    ) : (
      <div>
        {posts.map((post, i) => (
          <a data-animate data-animate-delay={i * 50} href={`/research/${post.id}/`}
             class="group flex items-baseline gap-5 py-5 border-b border-[var(--color-border-subtle)] last:border-b-0 transition-colors hover:border-[var(--color-border)]">
            <time class="text-xs text-[var(--color-text-muted)] shrink-0 tabular-nums w-16">
              {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
            </time>
            <span class="text-sm text-[var(--color-text-secondary)] group-hover:text-[var(--color-text)] transition-colors">{post.data.title}</span>
            <span class="ml-auto text-xs text-[var(--color-text-muted)] opacity-0 group-hover:opacity-100 transition-opacity shrink-0">Read →</span>
            {post.data.severity && (
              <span class:list={[
                "text-xs px-2 py-0.5 rounded-full shrink-0",
                post.data.severity === 'critical' && "text-[#ff3333] bg-[#ff3333]/8",
                post.data.severity === 'high' && "text-[#ff8833] bg-[#ff8833]/8",
                post.data.severity === 'medium' && "text-[#eab308] bg-[#eab308]/8",
                post.data.severity === 'low' && "text-[var(--color-accent)] bg-[var(--color-accent)]/8",
                post.data.severity === 'info' && "text-[var(--color-text-muted)] bg-[var(--color-surface)]",
              ]}>{post.data.severity}</span>
            )}
          </a>
        ))}
      </div>
    )}
  </section>
</Base>
