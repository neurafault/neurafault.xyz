---
import Base from '../../layouts/Base.astro';
import { tools } from '../../data/tools';

const statusColors: Record<string, string> = {
  'released': 'text-[var(--color-accent)] border-[var(--color-accent)]/30',
  'beta': 'text-[#ffcc00] border-[#ffcc00]/30',
  'in-development': 'text-[#ff8833] border-[#ff8833]/30',
  'planned': 'text-[var(--color-text-muted)] border-[var(--color-border)]',
};
---
<Base title="Tools" description="Open-source AI security tools by Neurafault.">
  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-16 sm:py-24">
    <h1 data-animate class="text-2xl sm:text-3xl font-bold tracking-tight mb-2">Tools</h1>
    <p data-animate data-animate-delay="100" class="text-[var(--color-text-secondary)] text-sm mb-10">
      Open-source tools for AI security research and testing.
    </p>

    {tools.length === 0 ? (
      <div data-animate data-animate-delay="200" class="border border-[var(--color-border)] rounded p-6 text-center space-y-3">
        <p class="text-[var(--color-text-muted)] text-sm">no releases yet</p>
        <p class="text-xs text-[var(--color-text-muted)]">
          Tools are in development. Star <a href="https://github.com/neurafault" class="text-[var(--color-accent)]">GitHub</a> to get notified.
        </p>
      </div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {tools.map((tool, i) => (
          <div data-animate data-animate-delay={100 + i * 80}
               class="p-4 bg-[var(--color-surface)] border border-[var(--color-border)] rounded hover:border-[var(--color-text-muted)] transition-all">
            <div class="flex items-center gap-2 mb-2">
              <h2 class="font-semibold text-sm text-[var(--color-accent)]">{tool.title}</h2>
              <span class={`ml-auto text-xs px-1.5 py-0.5 rounded border ${statusColors[tool.status]}`}>{tool.status}</span>
            </div>
            <p class="text-xs text-[var(--color-text-secondary)] mb-3">{tool.description}</p>
            <div class="flex items-center gap-3">
              {tool.tags.map(tag => (
                <span class="text-xs text-[var(--color-text-muted)]">#{tag}</span>
              ))}
              {tool.github && (
                <a href={tool.github} target="_blank" rel="noopener" class="ml-auto text-xs text-[var(--color-accent)] hover:underline">github ↗</a>
              )}
            </div>
          </div>
        ))}
      </div>
    )}
  </section>
</Base>
