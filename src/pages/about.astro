---
import Base from '../layouts/Base.astro';
import CopyLink from '../components/CopyLink.astro';
---
<Base title="About" description="About Neurafault — Independent AI Security Research Lab.">
  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-16 sm:py-24">
    <h1 data-animate class="text-2xl sm:text-3xl font-bold tracking-tight mb-8">About</h1>

    <div data-animate data-animate-delay="100" class="space-y-4 text-sm text-[var(--color-text-secondary)] leading-relaxed">
      <p>
        <span class="text-[var(--color-accent)] font-bold">Neurafault</span> is an independent AI security research lab
        focused on finding and exposing vulnerabilities in AI systems — LLMs, autonomous agents, multimodal models,
        and AI-powered pipelines.
      </p>
      <p>
        We operate at the intersection of mathematics, programming, artificial intelligence, and cybersecurity.
      </p>
      <p>
        AI security is one of the most critical and underexplored areas in tech. As AI systems are deployed into production
        at scale, the attack surface grows exponentially — and most teams aren't ready.
      </p>
    </div>

    <div data-animate data-animate-delay="200" class="border border-[var(--color-border)] rounded p-4 mt-8 space-y-2 text-sm">
      <p class="text-[var(--color-text-muted)] text-xs mb-3">$ cat ./operator</p>
      <p><span class="text-[var(--color-text-muted)]">name:</span> Dima</p>
      <p><span class="text-[var(--color-text-muted)]">handle:</span> <a href="https://hyrahmo.com" class="text-[var(--color-accent)]">@hyrahmo</a></p>
      <p><span class="text-[var(--color-text-muted)]">role:</span> Founder & Researcher</p>
      <p><span class="text-[var(--color-text-muted)]">focus:</span> AI agents, LLM security, adversarial ML</p>
    </div>

    <div data-animate data-animate-delay="300" class="mt-8 space-y-2 text-sm">
      <p class="text-[var(--color-text-muted)] text-xs">$ cat ./contact</p>
      <div class="space-y-1">
        <p><span class="text-[var(--color-text-muted)] mr-2">email:</span> <a href="mailto:dima@aetlas.pro" class="text-[var(--color-accent)]">dima@aetlas.pro</a></p>
        <p><span class="text-[var(--color-text-muted)] mr-2">github:</span> <a href="https://github.com/neurafault" class="text-[var(--color-accent)]">github.com/neurafault</a></p>
        <p><span class="text-[var(--color-text-muted)] mr-2">x.com:</span> <a href="https://x.com/neurafault" class="text-[var(--color-accent)]">@neurafault</a></p>
      </div>
    </div>

    <CopyLink />
  </section>
</Base>
