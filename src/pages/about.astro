---
import Base from '../layouts/Base.astro';
---
<Base title="About" description="About Neurafault — AI security research by Dima (@hyrahmo).">
  <section class="max-w-4xl mx-auto px-6 sm:px-8 py-20 sm:py-28">
    <h1 data-animate class="text-3xl sm:text-4xl font-bold tracking-[-0.03em] mb-12">About</h1>

    <div data-animate data-animate-delay="80" class="space-y-6 text-[15px] text-[var(--color-text-secondary)] leading-[1.85] max-w-2xl">
      <p>
        I'm <a href="https://hyrahmo.com" class="text-[var(--color-accent)] hover:underline underline-offset-4 font-medium">Dima</a> — security researcher focused on AI systems.
        <span class="text-[var(--color-text)]">Neurafault</span> is where I publish my research, tools, and writeups.
      </p>
      <p>
        I break LLMs, agents, and multimodal models. I also do traditional pentesting — web apps, APIs, infrastructure.
        The goal is simple: find the vulnerabilities before someone else does.
      </p>
      <p>
        My background is at the intersection of math, programming, and AI.
        I build with AI agents daily — which means I know where they're weak from the inside.
      </p>
    </div>

    <div data-animate data-animate-delay="160" class="mt-16">
      <div class="flex items-center gap-4 mb-8">
        <h2 class="section-label">Focus</h2>
        <div class="flex-1 h-px bg-[var(--color-border)]"></div>
      </div>
      <div class="flex flex-wrap gap-2">
        {[
          'Prompt Injection',
          'LLM Jailbreaks',
          'Agent Exploitation',
          'Adversarial ML',
          'OWASP LLM Top 10',
          'Web Pentesting',
          'API Security',
          'AI Red Teaming',
        ].map(item => (
          <span class="text-xs text-[var(--color-text-secondary)] py-1.5 px-3 rounded-full border border-[var(--color-border)] bg-[var(--color-surface)]">{item}</span>
        ))}
      </div>
    </div>

    <div data-animate data-animate-delay="240" class="mt-16">
      <div class="flex items-center gap-4 mb-8">
        <h2 class="section-label">Contact</h2>
        <div class="flex-1 h-px bg-[var(--color-border)]"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {[
          { label: 'Email', value: 'dima@aetlas.pro', href: 'mailto:dima@aetlas.pro' },
          { label: 'GitHub', value: 'neurafault', href: 'https://github.com/neurafault' },
          { label: 'X', value: '@neurafault', href: 'https://x.com/neurafault' },
          { label: 'YouTube', value: '@neurafault', href: 'https://youtube.com/@neurafault' },
        ].map(s => (
          <a href={s.href} target={s.href.startsWith('http') ? '_blank' : undefined} rel={s.href.startsWith('http') ? 'noopener' : undefined}
             class="glow-card px-5 py-4 flex items-center justify-between group">
            <span class="text-xs text-[var(--color-text-muted)]">{s.label}</span>
            <span class="text-sm text-[var(--color-text-secondary)] group-hover:text-[var(--color-accent)] transition-colors">{s.value}</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>
