---
import Base from '../layouts/Base.astro';
---
<Base title="About" description="About Neurafault — AI security research by Dima (@hyrahmo).">
  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-16 sm:py-24">
    <h1 data-animate class="text-2xl sm:text-3xl font-bold tracking-tight mb-10">About</h1>

    <div data-animate data-animate-delay="80" class="space-y-5 text-sm text-[var(--color-text-secondary)] leading-relaxed">
      <p>
        I'm <a href="https://hyrahmo.com" class="text-[var(--color-accent)] hover:underline font-medium">Dima</a> — security researcher focused on AI systems.
        <span class="text-[var(--color-text)] font-semibold">Neurafault</span> is where I publish my research, tools, and writeups.
      </p>
      <p>
        I break LLMs, agents, and multimodal models. I also do traditional pentesting — web apps, APIs, infrastructure.
        The goal is to find the gaps before attackers do.
      </p>
      <p>
        My background is at the intersection of math, programming, and AI.
        I build with AI agents daily — which gives me an unfair advantage in knowing where they're weak.
      </p>
    </div>

    <div data-animate data-animate-delay="160" class="mt-12">
      <h2 class="text-xs font-semibold text-[var(--color-text-muted)] uppercase tracking-widest mb-6">Focus</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
        {[
          'Prompt Injection',
          'LLM Jailbreaks',
          'Agent Exploitation',
          'Adversarial ML',
          'OWASP LLM Top 10',
          'Web & API Pentesting',
        ].map((item, i) => (
          <div class="text-xs text-[var(--color-text-secondary)] py-2 px-3 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)]">{item}</div>
        ))}
      </div>
    </div>

    <div data-animate data-animate-delay="240" class="mt-12">
      <h2 class="text-xs font-semibold text-[var(--color-text-muted)] uppercase tracking-widest mb-6">Contact</h2>
      <div class="space-y-3 text-sm">
        <a href="mailto:dima@aetlas.pro" class="flex items-center gap-3 text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] transition-colors">
          <span class="text-[var(--color-text-muted)] w-16 shrink-0">Email</span>
          <span>dima@aetlas.pro</span>
        </a>
        <a href="https://github.com/neurafault" class="flex items-center gap-3 text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] transition-colors">
          <span class="text-[var(--color-text-muted)] w-16 shrink-0">GitHub</span>
          <span>neurafault</span>
        </a>
        <a href="https://x.com/neurafault" class="flex items-center gap-3 text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] transition-colors">
          <span class="text-[var(--color-text-muted)] w-16 shrink-0">X</span>
          <span>@neurafault</span>
        </a>
        <a href="https://youtube.com/@neurafault" class="flex items-center gap-3 text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] transition-colors">
          <span class="text-[var(--color-text-muted)] w-16 shrink-0">YouTube</span>
          <span>@neurafault</span>
        </a>
      </div>
    </div>
  </section>
</Base>
