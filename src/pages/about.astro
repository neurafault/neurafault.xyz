---
import Base from '../layouts/Base.astro';
import CopyLink from '../components/CopyLink.astro';
---
<Base title="About" description="About Neurafault — Independent AI Security Research Lab.">
  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-16 sm:py-24">
    <h1 data-animate class="text-2xl sm:text-3xl font-bold tracking-tight mb-8">About</h1>

    <div data-animate data-animate-delay="100" class="space-y-4 text-sm text-[var(--color-text-secondary)] leading-relaxed">
      <p>
        <span class="text-[var(--color-text)] font-semibold">Neurafault</span> is an independent security research lab
        focused on offensive security — from AI systems (LLMs, agents, multimodal models) to web applications and APIs.
      </p>
      <p>
        We do pentesting, vulnerability research, and build open-source security tools.
        The work sits at the intersection of mathematics, programming, AI, and cybersecurity.
      </p>
      <p>
        As AI systems are deployed into production at scale, the attack surface grows exponentially —
        and most teams aren't ready. We help find the gaps before attackers do.
      </p>
    </div>

    <div data-animate data-animate-delay="200" class="border border-[var(--color-border)] rounded p-5 mt-10 space-y-3 text-sm">
      <h2 class="text-xs font-semibold text-[var(--color-text-muted)] uppercase tracking-wider mb-3">Operator</h2>
      <div class="grid grid-cols-[auto_1fr] gap-x-4 gap-y-2">
        <span class="text-[var(--color-text-muted)]">Name</span>
        <span>Dima</span>
        <span class="text-[var(--color-text-muted)]">Handle</span>
        <a href="https://hyrahmo.com" class="text-[var(--color-accent)] hover:underline">@hyrahmo</a>
        <span class="text-[var(--color-text-muted)]">Role</span>
        <span>Founder, Researcher & Pentester</span>
        <span class="text-[var(--color-text-muted)]">Focus</span>
        <span>AI security, pentesting, offensive security</span>
      </div>
    </div>

    <div data-animate data-animate-delay="300" class="mt-10">
      <h2 class="text-xs font-semibold text-[var(--color-text-muted)] uppercase tracking-wider mb-4">Contact</h2>
      <div class="grid grid-cols-[auto_1fr] gap-x-4 gap-y-2 text-sm">
        <span class="text-[var(--color-text-muted)]">Email</span>
        <a href="mailto:dima@aetlas.pro" class="text-[var(--color-accent)] hover:underline">dima@aetlas.pro</a>
        <span class="text-[var(--color-text-muted)]">GitHub</span>
        <a href="https://github.com/neurafault" class="text-[var(--color-accent)] hover:underline">github.com/neurafault</a>
        <span class="text-[var(--color-text-muted)]">X</span>
        <a href="https://x.com/neurafault" class="text-[var(--color-accent)] hover:underline">@neurafault</a>
      </div>
    </div>

    <CopyLink />
  </section>
</Base>
