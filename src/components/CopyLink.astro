---
<div class="flex flex-wrap items-center gap-3 my-6">
  <button id="copy-link" class="flex items-center gap-1.5 px-3 py-1.5 text-xs border border-[var(--color-border)] rounded text-[var(--color-text-muted)] hover:text-[var(--color-accent)] hover:border-[var(--color-accent)] transition-all cursor-pointer">
    <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
    </svg>
    <span class="copy-text">copy link</span>
  </button>

  <a href="https://docs.neurafault.xyz" class="flex items-center gap-1.5 px-3 py-1.5 text-xs border border-[var(--color-border)] rounded text-[var(--color-text-muted)] hover:text-[var(--color-accent)] hover:border-[var(--color-accent)] transition-all">
    docs ↗
  </a>

  <a href="/" class="flex items-center gap-1.5 px-3 py-1.5 text-xs border border-[var(--color-border)] rounded text-[var(--color-text-muted)] hover:text-[var(--color-accent)] hover:border-[var(--color-accent)] transition-all">
    cd /
  </a>
</div>

<script is:inline>
document.getElementById('copy-link')?.addEventListener('click', async function() {
  const btn = this;
  const textEl = btn.querySelector('.copy-text');
  const original = textEl.innerText;
  try {
    await navigator.clipboard.writeText(window.location.href);
    textEl.innerText = 'copied!';
    btn.style.borderColor = 'var(--color-accent)';
    btn.style.color = 'var(--color-accent)';
    setTimeout(() => {
      textEl.innerText = original;
      btn.style.borderColor = '';
      btn.style.color = '';
    }, 2000);
  } catch(e) { console.error(e); }
});
</script>
