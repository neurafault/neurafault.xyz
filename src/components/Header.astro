---
const path = Astro.url.pathname;

const nav = [
  { href: '/', label: 'Home' },
  { href: '/research/', label: 'Research' },
  { href: '/tools/', label: 'Tools' },
  { href: 'https://docs.neurafault.xyz', label: 'Docs', external: true },
  { href: '/about/', label: 'About' },
];
---
<header id="header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-4xl mx-auto px-6 sm:px-8 py-4 flex items-center justify-between">
    <a href="/" class="text-[var(--color-text)] font-bold tracking-[-0.02em] text-sm hover:text-[var(--color-accent)] transition-colors">
      neurafault
    </a>

    {/* Desktop */}
    <nav class="hidden md:flex items-center gap-6 text-[13px]">
      {nav.map(n => (
        <a
          href={n.href}
          class:list={[
            "text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors",
            !n.external && path.startsWith(n.href) && (n.href === '/' ? path === '/' : true) && "text-[var(--color-text)]",
          ]}
          {...(n.external ? { target: "_blank", rel: "noopener" } : {})}
        >
          {n.label}{n.external ? ' ↗' : ''}
        </a>
      ))}
    </nav>

    {/* Mobile */}
    <button id="burger" aria-label="Menu" class="md:hidden p-1 text-[var(--color-text)] cursor-pointer">
      <svg class="w-5 h-5 burger-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
      <svg class="w-5 h-5 burger-close hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden flex-col px-6 sm:px-8 pb-6 bg-[var(--color-bg)]/95 backdrop-blur-xl border-t border-[var(--color-border)] md:hidden">
    {nav.map(n => (
      <a
        href={n.href}
        class="py-3 text-sm text-[var(--color-text-secondary)] border-b border-[var(--color-border-subtle)] last:border-b-0 hover:text-[var(--color-text)] transition-colors"
        {...(n.external ? { target: "_blank", rel: "noopener" } : {})}
      >
        {n.label}{n.external ? ' ↗' : ''}
      </a>
    ))}
  </div>
</header>
